generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============= UNIFIED USER MODEL =============
model User {
  id                  String         @id @default(uuid())
  name                String
  email               String         @unique
  password            String
  phone               String?        @unique
  address             String?
  city                String?
  state               String?
  role                UserRole       @default(PUBLIC)
  status              UserStatus     @default(ACTIVE)
  isVerified          Boolean        @default(false)
  
  googleId            String?        @unique
  appleId             String?        @unique
  avatar              String?
  loginMethod         LoginMethod    @default(EMAIL)
  
  professionalDetails Json?
  
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  
  properties          Property[]
  enquiries           Enquiry[]
  legalRequests       LegalRequest[]
  legalServices       LegalService[]
  wishlists           Wishlist[]

  assignedChats ChatSession[] @relation("AssignedChats")
  userChats     ChatSession[] @relation("UserChats")

  @@map("users")
}

// ============= PROPERTY MODEL =============
model Property {
  id          String          @id @default(uuid())
  title       String
  description String
  type        PropertyType
  purpose     PropertyPurpose
  price       Float
  area        Float
  bedrooms    Int?
  bathrooms   Int?
  address     String
  city        String
  state       String
  pincode     String          @default("")
  features    String[]
  status      String          @default("AVAILABLE")
  latitude    Float?
  longitude   Float?
  images      Json?           @default("[]")

  areaUnit       String?  @default("sqft")
  soilType       String?
  waterSource    String?
  roadAccess     String?
  naPermission   Boolean  @default(false)
  clearTitle     Boolean  @default(false)
  approvedLayout Boolean  @default(false)

  brokerId    String
  broker      User            @relation(fields: [brokerId], references: [id], onDelete: Cascade)
  enquiries   Enquiry[]
  wishlists   Wishlist[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([brokerId])
  @@map("properties")
}

// ============= ENQUIRY MODEL =============
model Enquiry {
  id          String   @id @default(uuid())
  propertyId  String
  clientName  String
  clientEmail String
  clientPhone String
  message     String?
  status      String   @default("PENDING")
  brokerId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  broker      User     @relation(fields: [brokerId], references: [id], onDelete: Cascade)
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([brokerId])
  @@map("enquiries")
}

// ============= LEGAL SERVICE MODEL =============
model LegalService {
  id          String   @id @default(uuid())
  name        String
  description String
  price       Float
  category    String   @default("property")
  lawyerId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lawyer      User     @relation(fields: [lawyerId], references: [id], onDelete: Cascade)

  @@index([lawyerId])
  @@map("legal_services")
}

// ============= LEGAL REQUEST MODEL =============
model LegalRequest {
  id              String   @id @default(uuid())
  brokerId        String
  serviceType     String
  propertyDetails String
  clientName      String
  clientContact   String
  description     String?
  status          String   @default("PENDING")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  broker          User     @relation(fields: [brokerId], references: [id], onDelete: Cascade)

  @@index([brokerId])
  @@map("legal_requests")
}

// ============= LAND REQUIREMENT MODEL =============
model LandRequirement {
  id                 String   @id @default(uuid())
  name               String
  email              String
  phone              String
  purposeType        String
  landType           String
  minArea            Float
  maxArea            Float
  areaUnit           String
  preferredLocations String[]
  city               String   @default("Vadodara")
  state              String   @default("Gujarat")
  minBudget          Float
  maxBudget          Float
  features           String[]
  timeline           String
  additionalNotes    String?
  status             String   @default("ACTIVE")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("land_requirements")
}

// ============= WISHLIST MODEL =============
model Wishlist {
  id         String   @id @default(uuid())
  userId     String
  propertyId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId],     references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@index([userId])
  @@map("wishlists")
}

// ============= CHAT SESSION MODEL =============
model ChatSession {
  id         String   @id @default(uuid())
  userId     String?
  userName   String
  userEmail  String?
  userPhone  String?
  status     String   @default("ACTIVE")  // ACTIVE, CLOSED
  assignedTo String?

  // ✅ NEW — koni sathe chat che: ADMIN | BROKER | LAWYER
  sessionType String @default("ADMIN")

  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  messages   ChatMessage[]
  assignee   User?         @relation("AssignedChats", fields: [assignedTo], references: [id])
  user       User?         @relation("UserChats",     fields: [userId],     references: [id])

  @@index([userId])
  @@index([assignedTo])
  @@index([sessionType])  // ✅ NEW index for filtering
  @@map("chat_sessions")
}

// ============= CHAT MESSAGE MODEL =============
model ChatMessage {
  id         String   @id @default(uuid())
  sessionId  String
  senderId   String?
  senderName String
  senderRole String   @default("USER")  // USER | BOT | ADMIN | BROKER | LAWYER
  text       String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  session    ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("chat_messages")
}

// ============= ENUMS =============
enum UserRole {
  PUBLIC
  BROKER
  LAWYER
  ADMIN
}

enum UserStatus {
  ACTIVE
  PENDING
  REJECTED
  BLOCKED
}

enum LoginMethod {
  EMAIL
  GOOGLE
  APPLE
  WHATSAPP
  PHONE
}

enum PropertyType {
  RESIDENTIAL
  COMMERCIAL
  AGRICULTURAL
  INDUSTRIAL
  LAND
}

enum PropertyPurpose {
  SALE
  RENT
}

enum PropertyStatus {
  AVAILABLE
  SOLD
  RENTED
  UNDER_NEGOTIATION
}
